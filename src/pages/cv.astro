---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n';

const locale = 'es';
const t = useTranslations(locale);
---

<BaseLayout title={t('cv.title')} description={t('cv.description')} locale={locale} path="/cv">
  <h1 class="page-title">{t('cv.title')}</h1>
  <div class="max-w-2xl space-y-4">
    <p class="text-[var(--color-muted)]">{t('cv.description')}</p>
    <section class="card">
      <h2 class="mb-2 text-lg font-semibold text-[var(--color-text)]">{t('cv.summary')}</h2>
      <ul class="list-inside list-disc space-y-1 text-sm text-[var(--color-muted)]">
        <li>Ciberseguridad: writeups, laboratorios (TryHackMe, Hack The Box)</li>
        <li>Desarrollo: C, Android/Kotlin, Astro, TypeScript</li>
        <li>Impresión 3D: diseño CAD y producción FDM (PETG/PLA)</li>
      </ul>
      <p class="mt-4 text-sm text-[var(--color-muted)]">
        El PDF público no incluye email ni teléfono. Contacto vía formulario o LinkedIn.
      </p>
    </section>
    <p class="text-sm text-[var(--color-muted)]">
      Colocá tu CV en <code class="rounded bg-[var(--color-surface-elevated)] px-1.5 py-0.5 font-mono text-xs">public/cv.pdf</code> (sin metadata sensible) para habilitar descarga.
    </p>
  </div>
</BaseLayout>
