---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n';

const locale = 'en';
const t = useTranslations(locale);
---

<BaseLayout title={t('about.title')} description={t('about.description')} locale={locale} path="/en/about">
  <h1 class="page-title">{t('about.title')}</h1>
  <div class="prose-content max-w-2xl space-y-4">
    <p>{t('about.p1')}</p>
    <p>{t('about.p2')}</p>
    <p>{t('about.p3')}</p>
    <h2 class="pt-4 text-xl font-semibold">{t('about.skills')}</h2>
    <ul class="list-inside list-disc space-y-1">
      <li>Pentesting, CTFs and writeups (TryHackMe, Hack The Box)</li>
      <li>C, Kotlin/Android, Astro, TypeScript</li>
      <li>CAD modeling, PETG/PLA, FDM printing</li>
    </ul>
    <p class="pt-4">
      <a href="/en/cv" class="link-accent">{t('nav.cv')}</a>
      ·
      <a href="/en/contact" class="link-accent">{t('nav.contact')}</a>
      ·
      <a href="/en/links" class="link-accent">{t('nav.links')}</a>
    </p>
  </div>
</BaseLayout>
