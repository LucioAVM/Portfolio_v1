---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n';

const locale = 'en';
const t = useTranslations(locale);
---

<BaseLayout title={t('404.title')} description={t('404.description')} locale={locale} path="/en/404">
  <div class="py-20 text-center">
    <p class="section-label">404</p>
    <h1 class="mb-4 text-4xl font-bold">{t('404.title')}</h1>
    <p class="mb-6 text-[var(--color-muted)]">{t('404.description')}</p>
    <a href="/en/" class="btn-primary">{t('404.home')}</a>
  </div>
</BaseLayout>
