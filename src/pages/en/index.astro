---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Panel from '../../components/layout/Panel.astro';
import Hero from '../../components/Hero.astro';
import AboutSection from '../../components/home/AboutSection.astro';
import ProjectsHighlight from '../../components/home/ProjectsHighlight.astro';
import { useTranslations } from '../../i18n';
import { getProjects } from '../../utils/projects';
import { socialLinks } from '../../data/links';

const locale = 'en';
const t = useTranslations(locale);
const projects = await getProjects(locale);
const featured = projects.filter((p) => p.data.featured).slice(0, 3);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: t('site.title'),
  url: `${Astro.site}en/`,
  sameAs: socialLinks.map((l) => l.url),
  jobTitle: 'Cybersecurity & Software Development',
};
---

<BaseLayout title={t('site.title')} description={t('site.description')} locale={locale} path="/en/" section="home" variant="panels" jsonLd={jsonLd}>
  <Panel fadeContent>
    <Hero
      label={t('nav.home')}
      prefix={t('hero.prefix')}
      accent={t('hero.accent')}
      suffix={t('hero.suffix')}
      subtitle={t('hero.subtitle')}
      watermark={t('hero.watermark')}
    />
  </Panel>

  <Panel align="start">
    <AboutSection locale={locale} />
  </Panel>

  <Panel align="start" class="panel-featured">
    <ProjectsHighlight locale={locale} projects={featured} />
  </Panel>
</BaseLayout>
