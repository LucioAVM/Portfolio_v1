---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { useTranslations } from '../../i18n';
import { getProjects } from '../../utils/projects';
import { socialLinks } from '../../data/links';

const locale = 'en';
const t = useTranslations(locale);
const projects = await getProjects(locale);
const featured = projects.filter((p) => p.data.featured).slice(0, 3);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: t('site.title'),
  url: `${Astro.site}en/`,
  sameAs: socialLinks.map((l) => l.url),
  jobTitle: 'Cybersecurity & Software Development',
};
---

<BaseLayout title={t('site.title')} description={t('site.description')} locale={locale} path="/en/" section="home" jsonLd={jsonLd}>
  <Hero
    label={t('nav.home')}
    prefix={t('hero.prefix')}
    accent={t('hero.accent')}
    suffix={t('hero.suffix')}
    subtitle={t('site.tagline')}
    watermark={t('hero.watermark')}
    ctaPrimary={{ label: t('hero.cta.projects'), href: '/en/projects' }}
    ctaSecondary={{ label: t('hero.cta.contact'), href: '/en/contact' }}
    ctaTertiary={{ label: t('hero.cta.links'), href: '/en/links' }}
  />
  <section class="mt-16" data-reveal>
    <p class="section-label" data-reveal-item>{t('section.featured')}</p>
    <h2 class="section-title" data-reveal-item>{t('section.featured')}</h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-reveal-stagger>
      {featured.map((project) => <ProjectCard project={project} locale={locale} />)}
    </div>
  </section>
</BaseLayout>
