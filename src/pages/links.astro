---
import BaseLayout from '../layouts/BaseLayout.astro';
import LinkButton from '../components/LinkButton.astro';
import { socialLinks } from '../data/links';
import { useTranslations } from '../i18n';

const locale = 'es';
const t = useTranslations(locale);
---

<BaseLayout title={t('links.title')} description={t('links.description')} locale={locale} path="/links">
  <div class="mx-auto max-w-md text-center">
    <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/10 text-xl font-bold text-[var(--color-accent)]">
      LM
    </div>
    <h1 class="page-title">{t('links.title')}</h1>
    <p class="mb-8 text-[var(--color-muted)]">{t('links.description')}</p>
    <div class="flex flex-col gap-3">
      {socialLinks.map((link) => (
        <LinkButton link={link} locale={locale} />
      ))}
    </div>
  </div>
</BaseLayout>
