---
interface Props {
  title: string;
  description: string;
  locale: import('../i18n/config').Locale;
  path: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Minimi from '../components/Minimi.astro';
import { getCollection } from 'astro:content';

const { title, description, locale, path, jsonLd } = Astro.props;

const allQuotes = await getCollection('minimiQuotes');
const quotes = allQuotes
  .filter((q) => q.id.startsWith(`${locale}/`) || q.id.startsWith(`${locale}\\`))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .map((q) => ({ text: q.data.text }));
---

<!doctype html>
<html lang={locale} class="scroll-smooth dark">
  <head>
    <SeoHead title={title} description={description} locale={locale} path={path} jsonLd={jsonLd} />
  </head>
  <body class="flex min-h-screen flex-col antialiased">
    <Header locale={locale} currentPath={path} />
    <main class="mx-auto w-full max-w-6xl flex-1 px-4 py-10">
      <slot />
    </main>
    <Footer locale={locale} />
    <Minimi locale={locale} quotes={quotes} />
  </body>
</html>
