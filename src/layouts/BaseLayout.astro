---
import type { SectionKey } from '../lib/sections';
import { getSectionAccent, getSectionLabel, sectionFromPath } from '../lib/sections';
import { useTranslations } from '../i18n';

interface Props {
  title: string;
  description: string;
  locale: import('../i18n/config').Locale;
  path: string;
  section?: SectionKey;
  variant?: 'document' | 'panels';
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';
import Preloader from '../components/layout/Preloader.astro';
import AppBackground from '../components/layout/AppBackground.astro';
import TitleBar from '../components/layout/TitleBar.astro';
import SidebarNav from '../components/layout/SidebarNav.astro';
import StatusBar from '../components/layout/StatusBar.astro';
import Minimi from '../components/Minimi.astro';
import { getCollection } from 'astro:content';

const { title, description, locale, path, section, variant = 'document', jsonLd } = Astro.props;

const t = useTranslations(locale);

const resolvedSection: SectionKey = section ?? sectionFromPath(path);
const accent = getSectionAccent(resolvedSection);
const sectionLabel = getSectionLabel(locale, resolvedSection);
const accentStyle = `--color-accent:${accent.accent};--color-accent-secondary:${accent.secondary};`;

const allQuotes = await getCollection('minimiQuotes');
const quotes = allQuotes
  .filter((q) => q.id.startsWith(`${locale}/`) || q.id.startsWith(`${locale}\\`))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .map((q) => ({ text: q.data.text }));
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <SeoHead title={title} description={description} locale={locale} path={path} jsonLd={jsonLd} />
  </head>
  <body
    class="app-shell antialiased"
    data-section={resolvedSection}
    data-layout-variant={variant}
    style={accentStyle}
  >
    <Preloader locale={locale} />

    <div class="app-shell-inner">
      <AppBackground />
      <TitleBar locale={locale} currentPath={path} />
      <SidebarNav locale={locale} currentPath={path} />

      <div id="app-scroll" class="app-scroll">
        {
          variant === 'panels' ? (
            <main class="app-main-panels">
              <slot />
            </main>
          ) : (
            <main class="app-main mx-auto w-full max-w-6xl px-4 py-8 md:px-8 md:py-10">
              <slot />
            </main>
          )
        }
      </div>

      <StatusBar locale={locale} sectionLabel={sectionLabel} />
    </div>

    <Minimi locale={locale} quotes={quotes} />

    <script>
      import { initBgGlows } from '../lib/motion/bg-glows';
      import { initScrollReveal } from '../lib/motion/scroll-reveal';
      import { initScrollFocus } from '../lib/motion/scroll-focus';

      initBgGlows();
      initScrollReveal();
      initScrollFocus();
    </script>
  </body>
</html>
