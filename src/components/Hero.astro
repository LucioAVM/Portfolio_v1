---
interface Props {
  title: string;
  subtitle: string;
  ctaPrimary: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  ctaTertiary?: { label: string; href: string };
}

const { title, subtitle, ctaPrimary, ctaSecondary, ctaTertiary } = Astro.props;
---

<section class="relative overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] px-6 py-14 md:px-12 md:py-20">
  <div
    class="pointer-events-none absolute inset-0 opacity-30"
    aria-hidden="true"
    style="background-image: linear-gradient(var(--color-border) 1px, transparent 1px), linear-gradient(90deg, var(--color-border) 1px, transparent 1px); background-size: 48px 48px;"
  />
  <div class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-[var(--color-accent)]/10 blur-3xl" aria-hidden="true" />
  <div class="pointer-events-none absolute -bottom-16 -left-16 h-48 w-48 rounded-full bg-[var(--color-cyber)]/10 blur-3xl" aria-hidden="true" />

  <div class="relative z-10 max-w-2xl">
    <p class="section-label">Portfolio</p>
    <h1 class="mb-4 text-4xl font-bold tracking-tight md:text-5xl lg:text-6xl">
      {title}
    </h1>
    <p class="mb-8 max-w-xl text-lg text-[var(--color-muted)]">{subtitle}</p>
    <div class="flex flex-wrap gap-3">
      <a href={ctaPrimary.href} class="btn-primary">
        {ctaPrimary.label}
      </a>
      {ctaSecondary && (
        <a href={ctaSecondary.href} class="btn-secondary">
          {ctaSecondary.label}
        </a>
      )}
      {ctaTertiary && (
        <a href={ctaTertiary.href} class="btn-ghost">
          {ctaTertiary.label}
        </a>
      )}
    </div>
  </div>
</section>
