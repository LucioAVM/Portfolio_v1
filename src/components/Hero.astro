---
interface Props {
  label: string;
  prefix: string;
  accent: string;
  suffix: string;
  subtitle: string;
  watermark: string;
  ctaPrimary: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  ctaTertiary?: { label: string; href: string };
}

const { label, prefix, accent, suffix, subtitle, watermark, ctaPrimary, ctaSecondary, ctaTertiary } =
  Astro.props;
---

<section id="hero" class="hero-stage">
  <div class="hero-symbol-layer" aria-hidden="true">
    <span data-hero-symbol class="hero-symbol-wrap hero-sym-1"><span class="hero-symbol-float"><span class="hero-symbol">{`{`}</span></span></span>
    <span data-hero-symbol class="hero-symbol-wrap hero-sym-2"><span class="hero-symbol-float"><span class="hero-symbol">#</span></span></span>
    <span data-hero-symbol class="hero-symbol-wrap hero-sym-3"><span class="hero-symbol-float"><span class="hero-symbol">{`>`}</span></span></span>
    <span data-hero-symbol class="hero-symbol-wrap hero-sym-4"><span class="hero-symbol-float"><span class="hero-symbol">{`)`}</span></span></span>
  </div>

  <div class="hero-content relative z-10 mx-auto flex max-w-3xl flex-col items-center">
    <p data-hero-supertitle class="section-label motion-enter">{label}</p>

    <h1 class="hero-h1 mt-1 mb-5">
      <span data-hero-word class="motion-enter inline-block">{prefix}</span>
      {' '}
      <span data-hero-word class="motion-enter hero-accent inline-block">{accent}</span>
      {' '}
      <span data-hero-word class="motion-enter inline-block">{suffix}</span>
    </h1>

    <p data-hero-subtitle class="motion-enter mb-8 max-w-xl text-lg text-[var(--color-muted)]">
      {subtitle}
    </p>

    <div class="flex flex-wrap justify-center gap-3">
      <a data-hero-cta class="btn-primary motion-enter" href={ctaPrimary.href}>
        {ctaPrimary.label}
      </a>
      {ctaSecondary && (
        <a data-hero-cta class="btn-secondary motion-enter" href={ctaSecondary.href}>
          {ctaSecondary.label}
        </a>
      )}
      {ctaTertiary && (
        <a data-hero-cta class="btn-ghost motion-enter" href={ctaTertiary.href}>
          {ctaTertiary.label}
        </a>
      )}
    </div>
  </div>
</section>

<script>
  import { initHero } from '../lib/motion/hero';

  const hero = document.getElementById('hero');
  if (hero) initHero(hero);
</script>
