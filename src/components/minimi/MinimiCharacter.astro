---
interface Props {
  class?: string;
  compact?: boolean;
}

const { class: className = '', compact = false } = Astro.props;
const sizeClass = compact ? 'h-10 w-8' : 'h-16 w-14';
---

<svg
  id="minimi-svg"
  viewBox="0 0 80 96"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class:list={[
    'shrink-0 drop-shadow-[0_0_8px_rgba(52,211,153,0.22)] transition-transform duration-200',
    sizeClass,
    className,
  ]}
>
  <g id="minimi-root">
    <g id="minimi-body">
      <rect
        x="26"
        y="54"
        width="28"
        height="34"
        rx="12"
        class="fill-[var(--color-accent)]/22 stroke-[var(--color-accent)]"
        stroke-width="1.5"
      />
    </g>

    <g id="minimi-arm-l" transform="translate(28 62)">
      <path
        d="M0 0 C -2 6, -6 12, -4 18"
        stroke="var(--color-accent)"
        stroke-width="3"
        stroke-linecap="round"
        fill="none"
      />
    </g>

    <g id="minimi-arm-r" transform="translate(52 62)">
      <path
        d="M0 0 C 2 6, 6 12, 4 18"
        stroke="var(--color-accent)"
        stroke-width="3"
        stroke-linecap="round"
        fill="none"
      />
    </g>

    <g id="minimi-head" transform="rotate(2 40 30)">
      <path
        d="M 40 8 C 56 8, 66 18, 66 34 C 66 44, 58 52, 48 54 C 44 55, 36 55, 32 54 C 22 52, 14 44, 14 34 C 14 18, 24 8, 40 8 Z"
        class="fill-[var(--color-accent)]/20 stroke-[var(--color-accent)]"
        stroke-width="1.5"
        stroke-linejoin="round"
      />
      <circle id="minimi-eye-l" cx="32" cy="32" r="3" fill="var(--color-text)" />
      <circle id="minimi-eye-r" cx="48" cy="32" r="3" fill="var(--color-text)" />
      <rect
        id="minimi-eye-accent"
        x="50"
        y="30.5"
        width="2"
        height="3"
        rx="0.5"
        fill="var(--color-accent-secondary)"
      />
      <path
        d="M 34 40 L 46 40"
        stroke="var(--color-text)"
        stroke-width="1.5"
        stroke-linecap="round"
        opacity="0.75"
      />
    </g>
  </g>
</svg>
