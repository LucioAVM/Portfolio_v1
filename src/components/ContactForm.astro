---
import type { Locale } from '../i18n/config';
import { useTranslations } from '../i18n';
import { LINKEDIN_URL } from '../data/links';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '1x00000000000000000000AA';

const inputClass =
  'w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-elevated)] px-3 py-2 text-[var(--color-text)] transition focus:border-[var(--color-accent)] focus:outline-none';
---

<form id="contact-form" class="card mx-auto max-w-lg space-y-4" method="post" action="/api/contact">
  <div>
    <label for="name" class="mb-1 block text-sm font-medium text-[var(--color-text)]">{t('contact.name')}</label>
    <input id="name" name="name" type="text" required maxlength="100" autocomplete="name" class={inputClass} />
  </div>
  <div>
    <label for="message" class="mb-1 block text-sm font-medium text-[var(--color-text)]">{t('contact.message')}</label>
    <textarea id="message" name="message" required maxlength="2000" rows="5" class={inputClass} />
  </div>
  <div class="hidden" aria-hidden="true">
    <label for="website">Website</label>
    <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
  </div>
  <div class="cf-turnstile" data-sitekey={siteKey}></div>
  <p id="form-status" class="hidden text-sm" role="status"></p>
  <button type="submit" class="btn-primary w-full sm:w-auto disabled:opacity-50">
    {t('contact.submit')}
  </button>
  <p class="text-sm text-[var(--color-muted)]">
    <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer" class="link-accent">
      {t('contact.linkedin')}
    </a>
  </p>
</form>

<script define:vars={{ successMsg: t('contact.success'), errorMsg: t('contact.error') }}>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]');
    btn?.setAttribute('disabled', 'true');
    status?.classList.add('hidden');

    const fd = new FormData(form);
    const token = fd.get('cf-turnstile-response');
    fd.append('turnstileToken', token?.toString() ?? '');

    try {
      const res = await fetch('/api/contact', { method: 'POST', body: fd });
      const data = await res.json().catch(() => ({}));
      status?.classList.remove('hidden');
      if (res.ok) {
        status.textContent = successMsg;
        status.className = 'text-sm text-[var(--color-accent)]';
        form.reset();
      } else {
        status.textContent = data.error ?? errorMsg;
        status.className = 'text-sm text-red-400';
      }
    } catch {
      status?.classList.remove('hidden');
      status.textContent = errorMsg;
      status.className = 'text-sm text-red-400';
    } finally {
      btn?.removeAttribute('disabled');
    }
  });
</script>
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
