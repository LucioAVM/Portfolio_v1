---
import type { Locale } from '../i18n/config';
import { useTranslations } from '../i18n';
import { LINKEDIN_URL } from '../data/links';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '1x00000000000000000000AA';
---

<form id="contact-form" class="mx-auto max-w-lg space-y-4" method="post" action="/api/contact">
  <div>
    <label for="name" class="mb-1 block text-sm font-medium">{t('contact.name')}</label>
    <input
      id="name"
      name="name"
      type="text"
      required
      maxlength="100"
      autocomplete="name"
      class="w-full rounded-lg border border-zinc-300 px-3 py-2 dark:border-zinc-600 dark:bg-zinc-900"
    />
  </div>
  <div>
    <label for="message" class="mb-1 block text-sm font-medium">{t('contact.message')}</label>
    <textarea
      id="message"
      name="message"
      required
      maxlength="2000"
      rows="5"
      class="w-full rounded-lg border border-zinc-300 px-3 py-2 dark:border-zinc-600 dark:bg-zinc-900"
    />
  </div>
  <!-- Honeypot -->
  <div class="hidden" aria-hidden="true">
    <label for="website">Website</label>
    <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
  </div>
  <div class="cf-turnstile" data-sitekey={siteKey}></div>
  <p id="form-status" class="hidden text-sm" role="status"></p>
  <button
    type="submit"
    class="rounded-xl bg-cyan-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-cyan-700 disabled:opacity-50"
  >
    {t('contact.submit')}
  </button>
  <p class="text-sm text-zinc-500">
    <a
      href={LINKEDIN_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="text-cyan-600 hover:underline dark:text-cyan-400"
    >
      {t('contact.linkedin')}
    </a>
  </p>
</form>

<script define:vars={{ successMsg: t('contact.success'), errorMsg: t('contact.error') }}>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]');
    btn?.setAttribute('disabled', 'true');
    status?.classList.add('hidden');

    const fd = new FormData(form);
    const token = fd.get('cf-turnstile-response');
    fd.append('turnstileToken', token?.toString() ?? '');

    try {
      const res = await fetch('/api/contact', { method: 'POST', body: fd });
      const data = await res.json().catch(() => ({}));
      status?.classList.remove('hidden');
      if (res.ok) {
        status.textContent = successMsg;
        status.className = 'text-sm text-green-600';
        form.reset();
      } else {
        status.textContent = data.error ?? errorMsg;
        status.className = 'text-sm text-red-600';
      }
    } catch {
      status?.classList.remove('hidden');
      status.textContent = errorMsg;
      status.className = 'text-sm text-red-600';
    } finally {
      btn?.removeAttribute('disabled');
    }
  });
</script>
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
