---
import type { Locale } from '../i18n/config';
import { useTranslations } from '../i18n';
import MinimiCharacter from './minimi/MinimiCharacter.astro';

interface Props {
  locale: Locale;
  quotes: { text: string }[];
}

const { locale, quotes } = Astro.props;
const t = useTranslations(locale);
const quoteTexts = quotes.map((q) => q.text);
const initialQuote = quoteTexts[0] ?? '…';
---

<div
  id="minimi-slot"
  class="fixed bottom-4 right-4 z-30 hidden max-w-xs md:block"
  data-quotes={JSON.stringify(quoteTexts)}
  data-label-minimize={t('minimi.minimize')}
  data-label-expand={t('minimi.expand')}
  data-label-avatar={t('minimi.avatarExpand')}
  data-label-mascot={t('minimi.mascot')}
>
  <div class="flex items-end gap-2">
    <div
      id="minimi-bubble"
      class="minimi-bubble relative rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/95 p-3 pl-4 shadow-lg backdrop-blur"
    >
      <p id="minimi-quote" class="mb-2 text-sm text-[var(--color-muted)]" aria-live="polite">
        {initialQuote}
      </p>
      <button
        type="button"
        id="minimi-toggle"
        class="text-xs text-[var(--color-muted)] hover:text-[var(--color-accent)]"
        aria-expanded="true"
      >
        {t('minimi.minimize')}
      </button>
    </div>

    <button
      type="button"
      id="minimi-avatar-btn"
      class="rounded-full transition hover:scale-105 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
      aria-label={t('minimi.mascot')}
    >
      <span id="minimi-character-wrap" class="block origin-bottom transition-transform duration-200">
        <MinimiCharacter />
      </span>
    </button>
  </div>
</div>

<script>
  import { initMinimi } from '../lib/minimi/minimi-controller';

  const slot = document.getElementById('minimi-slot');
  if (slot) {
    initMinimi(slot, {
      minimize: slot.dataset.labelMinimize ?? 'Minimize',
      expand: slot.dataset.labelExpand ?? 'Expand',
      avatarExpand: slot.dataset.labelAvatar ?? 'Expand minimi',
      mascot: slot.dataset.labelMascot ?? 'Minimi',
    });
  }
</script>

<style>
  .minimi-bubble::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0.75rem;
    height: 0.75rem;
    border-top: 2px solid var(--color-accent-secondary);
    border-left: 2px solid var(--color-accent-secondary);
    border-top-left-radius: 0.5rem;
    opacity: 0.85;
  }

  #minimi-character-wrap[data-compact='true'] :global(#minimi-svg) {
    height: 2.5rem;
    width: 2rem;
  }
</style>
