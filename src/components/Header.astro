---
import type { Locale } from '../i18n/config';
import { getNavItems, useTranslations } from '../i18n';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const nav = getNavItems(locale);
const t = useTranslations(locale);
const homeHref = locale === 'es' ? '/' : '/en/';
---

<header class="sticky top-0 z-40 border-b border-zinc-200 bg-white/90 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/90">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a href={homeHref} class="font-semibold tracking-tight text-zinc-900 dark:text-zinc-50">
      {t('site.title')}
    </a>
    <nav class="hidden items-center gap-4 md:flex" aria-label="Main">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-sm transition-colors hover:text-cyan-600 dark:hover:text-cyan-400',
            currentPath === item.href || currentPath.startsWith(item.href + '/')
              ? 'text-cyan-600 dark:text-cyan-400 font-medium'
              : 'text-zinc-600 dark:text-zinc-300',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-2">
      <ThemeToggle locale={locale} currentPath={currentPath} />
      <button
        type="button"
        id="mobile-menu-btn"
        class="rounded-lg border border-zinc-300 p-2 md:hidden dark:border-zinc-600"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        ☰
      </button>
    </div>
  </div>
  <nav
    id="mobile-menu"
    class="hidden border-t border-zinc-200 px-4 py-3 dark:border-zinc-800 md:hidden"
    aria-label="Mobile"
  >
    <ul class="flex flex-col gap-2">
      {nav.map((item) => (
        <li>
          <a href={item.href} class="block py-1 text-sm text-zinc-700 dark:text-zinc-200">
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
