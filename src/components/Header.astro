---
import type { Locale } from '../i18n/config';
import { getNavItems, useTranslations } from '../i18n';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const nav = getNavItems(locale);
const t = useTranslations(locale);
const homeHref = locale === 'es' ? '/' : '/en/';

function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="glass-header sticky top-0 z-40">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a
      href={homeHref}
      class="font-semibold tracking-tight text-[var(--color-text)] transition hover:text-[var(--color-accent)]"
    >
      {t('site.title')}
    </a>
    <nav class="hidden items-center gap-1 md:flex" aria-label="Main">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'rounded-md px-3 py-1.5 text-sm transition',
            isActive(item.href)
              ? 'bg-[var(--color-accent)]/10 font-medium text-[var(--color-accent)]'
              : 'text-[var(--color-muted)] hover:text-[var(--color-text)]',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-2">
      <ThemeToggle locale={locale} currentPath={currentPath} />
      <button
        type="button"
        id="mobile-menu-btn"
        class="chip rounded-lg px-2.5 py-2 md:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Menu"
      >
        ☰
      </button>
    </div>
  </div>
  <nav
    id="mobile-menu"
    class="hidden border-t border-[var(--color-border)] px-4 py-3 md:hidden"
    aria-label="Mobile"
  >
    <ul class="flex flex-col gap-1">
      {nav.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block rounded-md px-3 py-2 text-sm',
              isActive(item.href) ? 'text-[var(--color-accent)]' : 'text-[var(--color-muted)]',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
