---
import type { Locale } from '../i18n/config';
import { getAlternateLocale } from '../i18n/config';
import { useTranslations } from '../i18n';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const t = useTranslations(locale);
const alt = getAlternateLocale(locale);

function switchPath(path: string, to: Locale): string {
  const map: Record<string, string> = {
    '/': '/en/',
    '/proyectos': '/en/projects',
    '/ciberseguridad': '/en/cybersecurity',
    '/impresion-3d': '/en/3d-printing',
    '/sobre-mi': '/en/about',
    '/contacto': '/en/contact',
    '/links': '/en/links',
    '/cv': '/en/cv',
    '/en/': '/',
    '/en/projects': '/proyectos',
    '/en/cybersecurity': '/ciberseguridad',
    '/en/3d-printing': '/impresion-3d',
    '/en/about': '/sobre-mi',
    '/en/contact': '/contacto',
    '/en/links': '/links',
    '/en/cv': '/cv',
  };
  if (path.startsWith('/proyectos/')) {
    return to === 'en' ? path.replace('/proyectos/', '/en/projects/') : path.replace('/en/projects/', '/proyectos/');
  }
  if (path.startsWith('/en/projects/')) {
    return to === 'es' ? path.replace('/en/projects/', '/proyectos/') : path;
  }
  if (to === 'en') return map[path] ?? `/en${path}`;
  return map[path] ?? (path.replace(/^\/en/, '') || '/');
}

const switchHref = switchPath(currentPath, alt);
---

<button type="button" class="app-util-btn js-theme-toggle" aria-label={t('theme.dark')}>
  <span class="dark:hidden" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none"><path d="M21.752 15.002A9.72 9.72 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg>
  </span>
  <span class="hidden dark:inline" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none"><path d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg>
  </span>
</button>
<a href={switchHref} class="app-util-btn app-util-lang" hreflang={alt} aria-label={t('lang.switch')}>
  {alt.toUpperCase()}
</a>

<script>
  const key = 'theme';
  const root = document.documentElement;
  const stored = localStorage.getItem(key);
  if (stored === 'dark' || (!stored && matchMedia('(prefers-color-scheme: dark)').matches)) {
    root.classList.add('dark');
  }
  document.querySelectorAll('.js-theme-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      root.classList.toggle('dark');
      localStorage.setItem(key, root.classList.contains('dark') ? 'dark' : 'light');
    });
  });
</script>
