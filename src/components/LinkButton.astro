---
import type { Locale } from '../i18n/config';
import type { LinkItem } from '../data/links';

interface Props {
  link: LinkItem;
  locale: Locale;
}

const { link, locale } = Astro.props;
const label = link.label[locale];
---

<a
  href={link.url}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    'flex w-full items-center justify-center rounded-xl border px-6 py-4 text-center font-medium transition',
    link.featured
      ? 'border-[var(--color-accent)]/50 bg-[var(--color-accent)] text-[#08090c] hover:brightness-110'
      : 'card card-hover border-[var(--color-border)] text-[var(--color-text)]',
  ]}
>
  {label}
</a>
