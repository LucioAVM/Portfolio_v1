---
import type { Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const brand = t('site.title');
const [firstName, ...restName] = brand.split(' ');
const lastName = restName.join(' ');
---

<div id="preloader" class="preloader" role="presentation">
  <div class="preloader-glow preloader-glow-1" aria-hidden="true"></div>
  <div class="preloader-glow preloader-glow-2" aria-hidden="true"></div>

  <div id="preloader-bar" class="preloader-bar">
    <span class="preloader-mono" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path
          d="M6 8.5 12 5l6 3.5M6 8.5 12 12M6 8.5v3.2L12 15m0-3 6-3.5m0 0v3.2L12 15m0 0v3.5"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </span>
    <span class="preloader-brand">
      <span class="app-brand-name">{firstName?.toLowerCase()}</span>
      <span class="app-brand-tag">&lt;{lastName.toLowerCase()}&gt;</span>
    </span>
    <span class="preloader-spin" aria-hidden="true"></span>
  </div>
</div>

<script>
  import { initPreloader } from '../../lib/motion/preloader';
  initPreloader();
</script>
