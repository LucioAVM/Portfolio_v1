---
import type { Locale } from '../../i18n/config';
import { useTranslations } from '../../i18n';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const t = useTranslations(locale);
const homeHref = locale === 'es' ? '/' : '/en/';

const brand = t('site.title');
const [firstName, ...restName] = brand.split(' ');
const lastName = restName.join(' ');
---

<header class="app-titlebar">
  <div class="app-titlebar-side">
    <a href={homeHref} class="app-monogram" aria-label={brand}>
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M6 8.5 12 5l6 3.5M6 8.5 12 12M6 8.5v3.2L12 15m0-3 6-3.5m0 0v3.2L12 15m0 0v3.5"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>
  </div>

  <a href={homeHref} class="app-brand" aria-label={brand}>
    <span class="app-brand-name">{firstName?.toLowerCase()}</span>
    <span class="app-brand-tag">&lt;{lastName.toLowerCase()}&gt;</span>
  </a>

  <div class="app-titlebar-side app-titlebar-actions">
    <span class="app-window-controls" aria-hidden="true">
      <span class="win-ctl">
        <svg viewBox="0 0 12 12" fill="none"><path d="M2.5 6h7" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path></svg>
      </span>
      <span class="win-ctl">
        <svg viewBox="0 0 12 12" fill="none"><rect x="2.6" y="2.6" width="6.8" height="6.8" rx="1.3" stroke="currentColor" stroke-width="1.1"></rect></svg>
      </span>
      <span class="win-ctl win-close">
        <svg viewBox="0 0 12 12" fill="none"><path d="M3 3l6 6M9 3l-6 6" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path></svg>
      </span>
    </span>
    <button
      type="button"
      id="mobile-menu-btn"
      class="app-hamburger lg:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Menu"
    >
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linecap="round"></path>
      </svg>
    </button>
  </div>
</header>
