---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../i18n/config';
import { useTranslations } from '../i18n';
import { projectDetailPath } from '../utils/projects';

interface Props {
  project: CollectionEntry<'projects'>;
  locale: Locale;
}

const { project, locale } = Astro.props;
const t = useTranslations(locale);
const { title, summary, category, tags, featured } = project.data;
const href = projectDetailPath(locale, project.data.slug);

const categoryLabels: Record<string, string> = {
  dev: t('category.dev'),
  ciberseguridad: t('category.ciberseguridad'),
  impresion3d: t('category.impresion3d'),
};

const categoryClass: Record<string, string> = {
  dev: 'category-dev',
  ciberseguridad: 'category-ciber',
  impresion3d: 'category-3d',
};
---

<article class="card card-hover group flex flex-col">
  <div class="mb-3 flex items-start justify-between gap-2">
    <span class:list={['rounded-md border px-2.5 py-0.5 text-xs font-medium', categoryClass[category]]}>
      {categoryLabels[category]}
    </span>
    {featured && <span class="text-xs text-amber-400" title="Featured">★</span>}
  </div>
  <h3 class="mb-2 text-lg font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)]">
    <a href={href}>{title}</a>
  </h3>
  <p class="mb-4 flex-1 text-sm text-[var(--color-muted)]">{summary}</p>
  {tags.length > 0 && (
    <ul class="mb-4 flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <li class="rounded border border-[var(--color-border)] bg-[var(--color-surface-elevated)] px-2 py-0.5 font-mono text-xs text-[var(--color-muted)]">
          {tag}
        </li>
      ))}
    </ul>
  )}
  <a href={href} class="link-accent text-sm font-medium">
    {t('project.view')} →
  </a>
</article>
