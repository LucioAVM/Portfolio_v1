---
interface Props {
  id: string;
  title: string;
  class?: string;
}

const { id, title, class: className } = Astro.props;
---

<article id={id} class:list={['win', className]} data-window>
  <header class="win-header" data-window-handle>
    <span class="win-title">{title}</span>
    <span class="win-controls" aria-hidden="true">
      <span class="win-ctl">
        <svg viewBox="0 0 12 12" fill="none"><path d="M2.5 6h7" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path></svg>
      </span>
      <span class="win-ctl">
        <svg viewBox="0 0 12 12" fill="none"><rect x="2.6" y="2.6" width="6.8" height="6.8" rx="1.3" stroke="currentColor" stroke-width="1.1"></rect></svg>
      </span>
      <span class="win-ctl win-close">
        <svg viewBox="0 0 12 12" fill="none"><path d="M3 3l6 6M9 3l-6 6" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path></svg>
      </span>
    </span>
  </header>
  <div class="win-body">
    <slot />
  </div>
</article>
